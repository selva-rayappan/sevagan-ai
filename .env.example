# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sevagan:sevagan_pass@localhost:5433/sevagan

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (use a different value for each secret)
JWT_SECRET=change-me-generate-a-strong-secret-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-generate-a-different-strong-secret
JWT_EXPIRES_IN=15m

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_APP_SECRET=your_app_secret_for_hmac_verification
WA_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# ─── MinIO (S3-Compatible Storage) ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=sevagan
MINIO_SECRET_KEY=sevagan_minio_pass
MINIO_BUCKET_NAME=sevagan-uploads

# ─── AI (Ollama) ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ─── OpenAI Fallback ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Admin Dashboard ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXTAUTH_SECRET=change-me-generate-a-strong-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Production Only (docker-compose.prod.yml / scripts/*.sh) ──────────────────
ADMIN_DOMAIN=admin.sevagan.in
API_DOMAIN=api.sevagan.in
# Full URL (scheme + host) the browser-side admin dashboard calls the API at.
# Baked into the web image at BUILD time (Next.js NEXT_PUBLIC_* inlining) —
# changing this requires `docker compose -f docker-compose.prod.yml build web`,
# a restart alone won't pick it up. Before a domain/SSL exist, point this at
# the bare EC2 IP (e.g. http://203.0.113.5) since bootstrap nginx serves both
# the dashboard and the API on that same host/port (same-origin, no CORS
# needed). Once real domains + SSL are live, switch to https://api.sevagan.in.
PUBLIC_API_URL=https://api.sevagan.in
LETSENCRYPT_EMAIL=selvakumar.rayappan@gmail.com
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
