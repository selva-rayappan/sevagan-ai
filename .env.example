# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sevagan:sevagan_pass@localhost:5433/sevagan

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (use a different value for each secret)
JWT_SECRET=change-me-generate-a-strong-secret-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-generate-a-different-strong-secret
JWT_EXPIRES_IN=15m

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_APP_SECRET=your_app_secret_for_hmac_verification
WA_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# ─── MinIO (S3-Compatible Storage) ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=sevagan
MINIO_SECRET_KEY=sevagan_minio_pass
MINIO_BUCKET_NAME=sevagan-uploads

# ─── AI (Ollama) ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ─── OpenAI Fallback ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Razorpay (UPI payment links) ───────────────────────────────────────────────
# From Razorpay Dashboard -> Settings -> API Keys (test or live mode).
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
# From Dashboard -> Settings -> Webhooks, when you register the webhook URL
# below and subscribe to the "payment_link.paid" event.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Webhook URL to register with Razorpay: <PUBLIC_API_URL>/api/v1/webhooks/razorpay
UPI_VPA=sevagan@upi

# ─── Admin Dashboard ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXTAUTH_SECRET=change-me-generate-a-strong-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Production Only (docker-compose.prod.yml / scripts/*.sh) ──────────────────
ADMIN_DOMAIN=admin.sevagan.co.in
API_DOMAIN=api.sevagan.co.in
# Root domain serving the static one-page marketing site (infrastructure/site/).
SITE_DOMAIN=sevagan.co.in
# Full public URL (scheme + host) of the API. Used two ways:
#  1. Baked into the web image at BUILD time as the browser-side API base URL
#     (Next.js NEXT_PUBLIC_* inlining) — changing this requires
#     `docker compose -f docker-compose.prod.yml build web`, a restart alone
#     won't pick it up.
#  2. Read at runtime by the backend to build the invoice-PDF link sent to
#     customers over WhatsApp — Meta's servers fetch that link directly, so it
#     must be a real HTTPS URL they can reach (not an internal Docker hostname).
# Before a domain/SSL exist, an HTTPS tunnel (e.g. ngrok) pointed at nginx
# works for both uses. Once real domains + SSL are live, use https://api.sevagan.co.in.
PUBLIC_API_URL=https://api.sevagan.co.in
LETSENCRYPT_EMAIL=selvakumar.rayappan@gmail.com
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
